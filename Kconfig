menu "WIZnet TOE Component"

config ESP_WIZ_TOE_ENABLED
    bool "Enable esp_wiz_toe"
    default y
    depends on IDF_TARGET_ESP32S3

if ESP_WIZ_TOE_ENABLED

config ESP_WIZ_TOE_SPI_HOST
    int "SPI host (2=SPI2, 3=SPI3)"
    range 2 3
    default 2

config ESP_WIZ_TOE_SPI_CLOCK_HZ
    int "SPI clock (Hz)"
    range 1000000 80000000
    default 20000000

config ESP_WIZ_TOE_PIN_MISO
    int "GPIO: MISO"
    default 13

config ESP_WIZ_TOE_PIN_MOSI
    int "GPIO: MOSI"
    default 11

config ESP_WIZ_TOE_PIN_SCLK
    int "GPIO: SCLK"
    default 12

config ESP_WIZ_TOE_PIN_CS
    int "GPIO: CS"
    default 10

config ESP_WIZ_TOE_PIN_RST
    int "GPIO: RESET"
    default 9

config ESP_WIZ_TOE_PIN_INT
    int "GPIO: INT"
    default 14

config ESP_WIZ_TOE_RX_BUF_KB
    int "Per-socket RX buffer size (KB)"
    range 1 16
    default 2

config ESP_WIZ_TOE_TX_BUF_KB
    int "Per-socket TX buffer size (KB)"
    range 1 16
    default 2

endif

endmenu
